{
  "name": "@vuepress/plugin-docsearch",
  "version": "2.0.0-rc.125",
  "description": "VuePress plugin - docsearch",
  "keywords": [
    "algolia",
    "docsearch",
    "plugin",
    "search",
    "vuepress",
    "vuepress-plugin"
  ],
  "homepage": "https://ecosystem.vuejs.press/plugins/search/docsearch.html",
  "bugs": {
    "url": "https://github.com/vuepress/ecosystem/issues"
  },
  "license": "MIT",
  "author": "meteorlxy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepress/ecosystem.git",
    "directory": "plugins/search/plugin-docsearch"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/client/styles/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./styles/*.css": "./dist/client/styles/*.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@docsearch/css": "^4.6.0",
    "@docsearch/js": "^4.6.0",
    "@vuepress/helper": "2.0.0-rc.125",
    "@vueuse/core": "^14.2.1",
    "ts-debounce": "^4.0.0",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@docsearch/react": "^4.6.0",
    "algoliasearch": "5.49.1"
  },
  "peerDependencies": {
    "vuepress": "2.0.0-rc.26"
  },
  "gitHead": "58e660bb7138f1883e5440a08903d09cdbabcdc8"
}
